{
	"name": "ScryfallLinks",
	"version": "2.1.0",
	"author": [
		"Nils Enevoldsen"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:ScryfallLinks",
	"descriptionmsg": "scryfalllinks-desc",
	"license-name": "MIT",
	"type": "parserhook",
	"requires": {
		"MediaWiki": ">= 1.43.0"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\ScryfallLinks\\": "src/"
	},
	"HookHandlers": {
		"ScryfallLinksHooks": {
			"class": "MediaWiki\\Extension\\ScryfallLinks\\Hooks"
		}
	},
	"Hooks": {
		"ParserFirstCallInit": "ScryfallLinksHooks"
	},
	"MessagesDirs": {
		"ScryfallLinks": [
			"i18n"
		]
	},
	"TrackingCategories": [
		"scryfalllinks-deck-category"
	],
	"ResourceModules": {
		"ext.scryfallLinks.tooltip": {
			"scripts": [
				"popover-polyfill.min.js",
				"ext.scryfallLinks.tooltip.js"
			],
			"styles": [
				"ext.scryfallLinks.css"
			],
			"targets": [
				"desktop",
				"mobile"
			],
			"messages": [
				"scryfalllinks-unrecognized-card",
				"scryfalllinks-card-tooltip-error"
			]
		},
		"ext.scryfallLinks.deckExport": {
			"scripts": [
				"ext.scryfallLinks.deckExport.js"
			],
			"targets": [
				"desktop",
				"mobile"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "ScryfallLinks/resources"
	},
	"manifest_version": 2
}
